#!/bin/bash
# tk-rec — record system audio and attach to a trapperkeeper note
#
# prerequisites:
#   brew install blackhole-2ch ffmpeg
#   then set up multi-output device in Audio MIDI Setup (one-time):
#     1. open Audio MIDI Setup
#     2. click + → Create Multi-Output Device
#     3. check your speakers/headphones AND BlackHole 2ch
#     4. set Multi-Output Device as system output
#
# usage:
#   tk-rec <note-id-or-url>    record and attach to note when done
#   tk-rec                     record only, print file path
#   tk-rec upload <file> <id>  upload existing file to note
#
# accepts full URLs or bare entry IDs:
#   tk-rec https://192.168.0.181:3443/journal/journal/2026/03/2026-03-11.md
#   tk-rec https://192.168.0.181:3443/notes/my-note-123456.md
#   tk-rec journal/2026/03/2026-03-11.md
#   tk-rec notes/my-note-123456.md
#   tk-rec upload ~/recordings/meeting.wav https://192.168.0.181:3443/journal/...

set -euo pipefail

TK_HOST="${TK_HOST:-http://localhost:3001}"

# auto-detect TK_HOST from URL argument if provided
_detect_host() {
  local input="${1:-}"
  if [[ "$input" =~ ^(https?://[^/]+) ]]; then
    TK_HOST="${BASH_REMATCH[1]}"
  fi
}
_detect_host "${1:-}"
# for upload subcommand, detect from the 3rd arg (the URL)
[ "${1:-}" = "upload" ] && _detect_host "${3:-}"
REC_DIR="${HOME}/recordings"
mkdir -p "$REC_DIR"

# colors
CYAN='\033[0;36m'
PINK='\033[0;35m'
GREEN='\033[0;32m'
RED='\033[0;31m'
DIM='\033[2m'
NC='\033[0m'

# extract entry ID from URL or bare path
# https://host:port/journal/journal/2026/03/2026-03-11.md → journal/2026/03/2026-03-11.md
# https://host:port/notes/notes/my-note-123.md → notes/my-note-123.md
parse_entry_id() {
  local input="$1"
  # strip URL prefix if present (everything up to and including the port/host)
  local path="${input}"
  if [[ "$input" =~ ^https?:// ]]; then
    # remove scheme + host + port, leaving /journal/journal/... or /notes/notes/...
    path=$(echo "$input" | sed -E 's|^https?://[^/]+||')
  fi
  # URL structure is /<category>/<filepath> where filepath starts with category again
  # e.g. /journal/journal/2026/03/2026-03-11.md → journal/2026/03/2026-03-11.md
  # e.g. /notes/notes/my-note.md → notes/my-note.md
  # strip leading slash, then remove the first path segment (the route prefix)
  path="${path#/}"
  local route="${path%%/*}"
  local rest="${path#*/}"
  # the rest IS the entry ID (journal/2026/03/... or notes/my-note-...)
  echo "$rest"
}

banner() {
  echo -e "${CYAN}┌─────────────────────────────┐${NC}"
  echo -e "${CYAN}│${NC}  tk-rec ${DIM}// trapperkeeper${NC}    ${CYAN}│${NC}"
  echo -e "${CYAN}└─────────────────────────────┘${NC}"
}

upload_to_note() {
  local file="$1"
  local entry_id="$2"

  echo -e "${DIM}uploading to ${entry_id}...${NC}"
  response=$(curl -sk -w "\n%{http_code}" \
    -F "file=@${file}" \
    -F "entryId=${entry_id}" \
    "${TK_HOST}/api/assets/attach")

  http_code=$(echo "$response" | tail -1)
  body=$(echo "$response" | sed '$d')

  if [ "$http_code" = "200" ]; then
    echo -e "${GREEN}attached${NC} → ${body}" | grep -o '"url":"[^"]*"' | head -1
    echo -e "${GREEN}done.${NC} recording linked in note."
  else
    echo -e "${RED}upload failed${NC} (HTTP ${http_code})"
    echo "$body"
    return 1
  fi
}

# handle upload subcommand
if [ "${1:-}" = "upload" ]; then
  if [ $# -lt 3 ]; then
    echo "usage: tk-rec upload <file> <note-id-or-url>"
    exit 1
  fi
  upload_to_note "$2" "$(parse_entry_id "$3")"
  exit 0
fi

NOTE_ID=""
if [ -n "${1:-}" ]; then
  NOTE_ID="$(parse_entry_id "$1")"
fi
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
OUTFILE="${REC_DIR}/meeting-${TIMESTAMP}.ogg"

banner
echo ""

# check blackhole — cache device list, case-insensitive match
DEVICE_LIST=$(ffmpeg -f avfoundation -list_devices true -i "" 2>&1 || true)
if ! echo "$DEVICE_LIST" | grep -iq "blackhole"; then
  echo -e "${RED}BlackHole not found.${NC}"
  echo -e "${DIM}install: brew install blackhole-2ch${NC}"
  echo -e "${DIM}then set up multi-output device in Audio MIDI Setup${NC}"
  echo ""
  echo -e "${DIM}detected audio devices:${NC}"
  echo "$DEVICE_LIST" | grep -E "^\[" | head -20
  exit 1
fi

# find blackhole device index — match only the device index bracket, not the hex address
BH_INDEX=$(echo "$DEVICE_LIST" | \
  grep -i "blackhole" | sed -E 's/.*\] \[([0-9]+)\].*/\1/' | head -1)

if [ -z "$BH_INDEX" ]; then
  echo -e "${RED}could not find BlackHole device index${NC}"
  exit 1
fi

# list available mic devices (exclude BlackHole — that's system audio)
AUDIO_DEVICES=$(echo "$DEVICE_LIST" | awk '/AVFoundation audio devices:/,0' | grep -i "\[.*\].*\[" | grep -iv "blackhole")

if [ -n "${TK_MIC:-}" ]; then
  # env override — skip picker
  MIC_INDEX="$TK_MIC"
else
  # show picker
  echo -e "  ${DIM}available microphones:${NC}"
  echo "$AUDIO_DEVICES" | while IFS= read -r line; do
    idx=$(echo "$line" | sed -E 's/.*\] \[([0-9]+)\].*/\1/')
    name=$(echo "$line" | sed -E 's/.*\] \[[0-9]+\] //')
    echo -e "    ${CYAN}${idx}${NC}  ${name}"
  done
  echo ""
  printf "  select mic [1]: "
  read -r MIC_CHOICE
  MIC_INDEX="${MIC_CHOICE:-1}"
fi

MIC_NAME=$(echo "$AUDIO_DEVICES" | grep "\[${MIC_INDEX}\]" | sed -E 's/.*\] \[[0-9]+\] //')

echo -e "  ${DIM}system:${NC} BlackHole 2ch [:${BH_INDEX}]"
echo -e "  ${DIM}mic:${NC}    ${MIC_NAME:-device} [:${MIC_INDEX}]"
echo -e "  ${DIM}output:${NC} ${OUTFILE}"
if [ -n "$NOTE_ID" ]; then
  echo -e "  ${DIM}attach:${NC} ${NOTE_ID}"
fi
echo ""
echo -e "  ${PINK}recording...${NC} press ${CYAN}Ctrl+C${NC} to stop"
echo ""

# record — capture both system audio (BlackHole) and mic, mix into one stream
trap '' INT
ffmpeg -y \
  -f avfoundation -i ":${BH_INDEX}" \
  -f avfoundation -i ":${MIC_INDEX}" \
  -filter_complex "\
    [0:a]volume=0.4[sys];\
    [1:a]volume=0.3[mic];\
    [sys][mic]amix=inputs=2:duration=longest:normalize=0[out]" \
  -map "[out]" -ac 1 -ar 48000 -c:a libopus -b:a 64k "$OUTFILE" 2>"${REC_DIR}/ffmpeg.log" &
FFMPEG_PID=$!

# wait for ctrl+c
wait $FFMPEG_PID 2>/dev/null || true
trap - INT

echo ""

# check file exists and has content
if [ ! -f "$OUTFILE" ] || [ ! -s "$OUTFILE" ]; then
  echo -e "${RED}no audio captured${NC}"
  exit 1
fi

SIZE=$(du -h "$OUTFILE" | cut -f1)
echo -e "  ${GREEN}saved${NC} ${OUTFILE} (${SIZE})"

# upload if note ID provided
if [ -n "$NOTE_ID" ]; then
  echo ""
  upload_to_note "$OUTFILE" "$NOTE_ID"
else
  echo ""
  echo -e "  ${DIM}to attach later:${NC}"
  echo -e "  tk-rec upload ${OUTFILE} <note-id>"
fi
